   if (user?.phone) score += 15;
   if ((profile?.preferredLocations ?? []).length > 0) score += 15;
   if ((profile?.skills ?? []).length > 0) score += 15;
   if ((profile?.education ?? []).length > 0) score += 15;
   if (profile?.resumeUrl) score += 10;
   return score;
 }
 
