+function normalizePhone(raw: unknown): string {
+  const cleaned = String(raw ?? "").replace(/[^\d+]/g, "").trim();
+  if (!cleaned) return "";
+  if (cleaned.startsWith("+")) return cleaned;
+  if (cleaned.length === 10) return `+91${cleaned}`;
+  return `+${cleaned}`;
